#!/usr/bin/env bash

# Exit immediately on errors
set -euo pipefail

# Notification configuration
NOTIFY_TIMEOUT=5000  # 5 seconds

# Check if NetworkManager is installed
if ! command -v nmcli &> /dev/null; then
    notify-send -t "$NOTIFY_TIMEOUT" "Error" "NetworkManager (nmcli) is not installed"
    exit 1
fi

# Function to get wifi state
get_wifi_state() {
    nmcli -g WIFI radio wifi | tr '[:upper:]' '[:lower:]'
}

# Start NetworkManager if not running
if ! systemctl is-active --quiet NetworkManager; then
    if ! pkexec systemctl start NetworkManager; then
        notify-send -t "$NOTIFY_TIMEOUT" "Error" "Failed to start NetworkManager"
        exit 1
    fi
    # Wait for service to initialize
    sleep 2
fi

# Scan networks and handle errors
if ! nmcli device wifi rescan; then
    notify-send -t "$NOTIFY_TIMEOUT" "Error" "Failed to scan Wi-Fi networks"
    exit 1
fi

# Get wifi list with proper parsing
wifi_list=$(nmcli --terse --fields SSID,SECURITY,BSSID,ACTIVE device wifi list | \
    awk -F':' '{
        ssid = $1
        security = ($2 == "--") ? "" : ""
        status = ($4 == "yes") ? " " : ""
        print status security ":" ssid
    }' | sort -u -t':' -k2,2)

# Create toggle option based on current state
wifi_state=$(get_wifi_state)
if [[ "$wifi_state" == "enabled" ]]; then
    toggle="󱛅  Disable Wi-Fi"
else
    toggle="󱚽  Enable Wi-Fi"
fi

# Show network selection using rofi
chosen=$(echo -e "$toggle\n$wifi_list" | rofi -dmenu -i -sep ':' -selected-row 1 -p "Wi-Fi" | cut -d':' -f2-)
[[ -z "$chosen" ]] && exit 0  # Exit if nothing selected

# Handle toggle action
if [[ "$chosen" == "Disable Wi-Fi" || "$chosen" == "Enable Wi-Fi" ]]; then
    new_state=$( [[ "$chosen" == "Enable Wi-Fi" ]] && echo "on" || echo "off" )
    nmcli radio wifi "$new_state"
    notify-send -t "$NOTIFY_TIMEOUT" "Wi-Fi" "Wi-Fi ${new_state}"
    exit 0
fi

# Extract SSID from selection (handle special characters)
ssid=$(sed 's/\\/\\\\/g; s/"/\\"/g' <<< "$chosen")

# Check if connection already exists
existing_conn=$(nmcli -g NAME connection show | grep -Fxm1 "$ssid" || true)

if [[ -n "$existing_conn" ]]; then
    # Try existing connection
    if nmcli connection up "$existing_conn"; then
        notify-send -t "$NOTIFY_TIMEOUT" "Connected" "Successfully connected to $ssid"
        exit 0
    else
        # Remove failed connection and try fresh
        nmcli connection delete "$existing_conn" >/dev/null
    fi
fi

# Check if network is secured
security=$(nmcli --terse --fields SSID,SECURITY device wifi list | \
           awk -F':' -v ssid="$ssid" '$1 == ssid {print $2; exit}')

# Get password if secured
password=""
if [[ -n "$security" && "$security" != "--" ]]; then
    password=$(rofi -dmenu -password -p "Password for $ssid: ")
    [[ -z "$password" ]] && { notify-send -t "$NOTIFY_TIMEOUT" "Error" "No password provided"; exit 1; }
fi

# Connect to network
if nmcli device wifi connect "$ssid" password "$password"; then
    notify-send -t "$NOTIFY_TIMEOUT" "Connected" "Successfully connected to $ssid"
else
    notify-send -t "$NOTIFY_TIMEOUT" "Error" "Failed to connect to $ssid"
    exit 1
fi
