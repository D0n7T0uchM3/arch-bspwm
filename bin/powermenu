#!/bin/env bash

logout() {
	# For each opened window
	bspc query --nodes | while read -r winid; do
		# Close it
		xdotool windowkill "$winid"
	done
	# TODO Kill programs
    #	

	# Quit bspwm
	bspc quit 1
}

choice=$(printf "Lock\nLogout\nSuspend\nReboot\nShutdown" | rofi -dmenu -p 'Start  ')
case "$choice" in
  Lock) sh $HOME/bin/screen-lock ;;
  Logout) logout ;;
  # Logout) pkill -KILL -u "$USER" ;;
  Suspend) systemctl suspend && sh $HOME/bin/screen-lock ;;
  Reboot) systemctl reboot ;;
  Shutdown) systemctl poweroff ;;
esac
